{
    "compilerOptions": {
        "module": "NodeNext",
        "esModuleInterop": true,
        "target": "ESNext",
        "moduleResolution": "NodeNext",
        "resolveJsonModule": true,
        "types": ["node"],
        "allowSyntheticDefaultImports": true,
        "sourceMap": true,
        "outDir": "dist",
        "importHelpers": true,
        "allowJs": true,
        "strict": true
    },
    "lib": ["ESNext"],
    "include": ["src"]
}
