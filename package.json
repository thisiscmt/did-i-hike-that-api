{
    "name": "did-i-hike-that-api",
    "version": "1.4.0",
    "description": "APIs for the Did I Hike That? web app",
    "author": "Chris Tybur",
    "private": true,
    "license": "MIT",
    "main": "index.js",
    "scripts": {
        "build": "rimraf ./dist && tsc",
        "checkpoint": "npm run build && copyfiles app_data/did_i_hike_that.* dist && cd dist && node db/checkpointDatabase.js",
        "init-db": "npm run build && node dist/db/initDatabase.js",
        "lint": "eslint ./src",
        "pm2": "npm run build && copyfiles ecosystem.config.json dist && copyfiles app_data/did_i_hike_that.* dist && cd dist && pm2 start ecosystem.config.json --no-daemon --output diht_api.log --error diht_api_error.log --time",
        "start": "npm run build && node dist/index.js"
    },
    "dependencies": {
        "connect-session-sequelize": "^8.0.6",
        "copyfiles": "^2.4.1",
        "cors": "^2.8.6",
        "express": "^5.2.1",
        "express-session": "^1.19.0",
        "helmet": "^8.1.0",
        "multer": "^2.1.1",
        "sequelize": "^6.37.8",
        "sharp": "^0.34.5",
        "sqlite3": "^5.1.7",
        "umzug": "^3.7.0",
        "uuid": "^13.0.1",
        "winston": "^3.19.0"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.4",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/express-session": "^1.18.2",
        "@types/multer": "^2.1.0",
        "@types/node": "^24.12.0",
        "@types/uuid": "^11.0.0",
        "eslint": "^9.39.4",
        "rimraf": "^6.1.3",
        "tslib": "^2.8.1",
        "typescript": "^5.9.2",
        "typescript-eslint": "^8.56.1"
    },
    "type": "module"
}
